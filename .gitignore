# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Logs
*.log

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# Temporary files
*.tmp
*.temp
*.bak
~$*

# Local data exports that should not be versioned by default
data/raw/*.zip
data/raw/*.7z
data/raw/*.rar

# Optional large binary outputs
figures/*.pdf
figures/*.tiff
